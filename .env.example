# Database Configuration
# Port 5433 untuk tidak conflict dengan container lain
# Ubah ke port lain jika sudah dipakai
DB_HOST=postgres
DB_PORT=5433
DB_USER=christ_user
DB_PASSWORD=christ_password
DB_NAME=christ_db
DB_SSLMODE=disable

# API Configuration
# Port 3001 untuk tidak conflict dengan container lain
# Ubah ke port lain jika sudah dipakai
API_PORT=3001

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-secret
